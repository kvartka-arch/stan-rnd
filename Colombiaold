<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Colombia R&D: Payment Providers &amp; Fields</title>
<style>
  :root {
    --bg: #f7f7fb;
    --surface: #ffffff;
    --border: #e4e2f0;
    --purple: #6c47d8;
    --purple-light: #ede9fc;
    --purple-mid: #a98ced;
    --graphite: #1c1a2e;
    --gray: #6b6882;
    --gray-light: #f0eff7;
    --blue: #2563eb;
    --blue-light: #eff6ff;
    --green: #059669;
    --green-light: #ecfdf5;
    --shadow: 0 2px 12px rgba(108,71,216,0.08);
    --shadow-lg: 0 4px 24px rgba(108,71,216,0.13);
    --radius: 12px;
    --radius-sm: 7px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    background: var(--bg);
    color: var(--graphite);
    font-size: 13.5px;
    line-height: 1.55;
    padding: 0;
  }
  /* HEADER */
  .doc-header {
    background: linear-gradient(135deg, #1c1a2e 0%, #3b2f7e 60%, #6c47d8 100%);
    color: white;
    padding: 48px 48px 40px;
    position: relative;
    overflow: hidden;
  }
  .doc-header::before {
    content: '';
    position: absolute; top: -60px; right: -60px;
    width: 300px; height: 300px;
    background: rgba(255,255,255,0.04);
    border-radius: 50%;
  }
  .doc-header::after {
    content: '';
    position: absolute; bottom: -80px; left: 30%;
    width: 200px; height: 200px;
    background: rgba(255,255,255,0.03);
    border-radius: 50%;
  }
  .doc-header h1 {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.5px;
    margin-bottom: 6px;
    position: relative;
  }
  .doc-header .subtitle {
    font-size: 13px;
    color: rgba(255,255,255,0.6);
    letter-spacing: 0.5px;
    position: relative;
  }
  .doc-header .pill-row {
    display: flex; gap: 8px; margin-top: 18px; position: relative;
  }
  .doc-header .pill {
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 20px;
    padding: 3px 12px;
    font-size: 11px;
    color: rgba(255,255,255,0.8);
    letter-spacing: 0.3px;
  }
  /* TOC */
  .toc-bar {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 10px 32px;
    display: flex; gap: 6px; flex-wrap: wrap; align-items: center;
  }
  .toc-bar a {
    font-size: 11.5px;
    color: var(--gray);
    text-decoration: none;
    padding: 3px 10px;
    border-radius: 20px;
    border: 1px solid var(--border);
    transition: all 0.15s;
    white-space: nowrap;
  }
  .toc-bar a:hover { background: var(--purple-light); color: var(--purple); border-color: var(--purple-mid); }
  /* MAIN CONTENT */
  .content { padding: 28px 32px; max-width: min(96vw, 1700px); width: 100%; }
  /* SECTION HEADERS */
  .section-label {
    display: inline-block;
    background: var(--purple);
    color: white;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 4px;
    margin-bottom: 10px;
  }
  .payment-method-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--graphite);
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .payment-method-title .method-icon {
    width: 32px; height: 32px;
    background: var(--purple-light);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px;
  }
  .section-desc {
    font-size: 12.5px;
    color: var(--gray);
    margin-bottom: 18px;
  }
  .section-divider {
    height: 1px;
    background: var(--border);
    margin: 40px 0;
  }
  .big-section-title {
    font-size: 22px;
    font-weight: 700;
    color: var(--graphite);
    margin-bottom: 4px;
  }
  .big-section-sub {
    font-size: 13px;
    color: var(--gray);
    margin-bottom: 24px;
  }
  /* TABLES */
  .table-wrap {
    background: var(--surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
    margin-bottom: 32px;
    border: 1px solid var(--border);
  }
  table {
    width: 100%;
    border-collapse: collapse;
  }
  thead th {
    background: var(--gray-light);
    color: var(--gray);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    padding: 10px 14px;
    text-align: left;
    border-bottom: 1px solid var(--border);
  }
  tbody tr:not(:last-child) td { border-bottom: 1px solid var(--border); }
  tbody tr:hover td { background: #faf9ff; }
  td {
    padding: 10px 14px;
    vertical-align: middle;
    font-size: 13px;
  }
  td.provider-cell {
    font-family: 'Consolas', 'SF Mono', monospace;
    font-size: 11.5px;
    font-weight: 600;
    color: var(--graphite);
    background: #faf9ff;
    vertical-align: middle;
    text-align: center;
    border-right: 2px solid var(--purple-light);
    width: 17%;
  }
  td.merchant-cell {
    font-weight: 600;
    color: var(--graphite);
    font-size: 12.5px;
    white-space: nowrap;
  }
  /* BADGES */
  .badge-wrap { display: flex; flex-wrap: wrap; gap: 4px; align-items: center; }
  .badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 500;
    white-space: nowrap;
  }
  .badge-merchant {
    background: var(--blue-light);
    color: #1d4ed8;
    border: 1px solid #bfdbfe;
  }
  .badge-provider {
    background: var(--purple-light);
    color: var(--purple);
    border: 1px solid #c4b5fd;
  }
  .badge-dash {
    color: #bbb;
    font-size: 12px;
  }
  /* SUMMARY CARDS */
  .provider-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 18px 20px;
    margin-bottom: 14px;
    box-shadow: var(--shadow);
  }
  .provider-card-name {
    font-family: 'Consolas', 'SF Mono', monospace;
    font-size: 12.5px;
    font-weight: 700;
    color: var(--purple);
    margin-bottom: 10px;
    display: flex; align-items: center; gap: 8px;
  }
  .provider-card-name::before {
    content: '';
    display: inline-block;
    width: 8px; height: 8px;
    background: var(--purple);
    border-radius: 50%;
  }
  .pm-method-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 5px;
    font-size: 12.5px;
  }
  .pm-method-tag {
    font-weight: 700;
    color: var(--graphite);
    min-width: 130px;
    font-size: 11.5px;
    background: var(--gray-light);
    padding: 2px 8px;
    border-radius: 4px;
    white-space: nowrap;
  }
  .pm-merchants {
    color: var(--gray);
    font-size: 12px;
  }
  /* MERCHANT SUMMARY TABLE */
  .badge-pm {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 10.5px;
    font-weight: 600;
    background: var(--green-light);
    color: var(--green);
    border: 1px solid #a7f3d0;
    white-space: nowrap;
  }
  /* FINDINGS */
  .finding-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 24px;
    box-shadow: var(--shadow);
  }
  .finding-header {
    background: linear-gradient(90deg, var(--purple) 0%, var(--purple-mid) 100%);
    color: white;
    padding: 12px 20px;
    font-weight: 700;
    font-size: 15px;
    display: flex; align-items: center; gap: 10px;
  }
  .finding-body { padding: 20px; display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .finding-block { }
  .finding-block-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 7px;
    padding-bottom: 5px;
    border-bottom: 1px solid var(--border);
  }
  .finding-list { list-style: none; }
  .finding-list li {
    font-size: 12.5px;
    color: var(--graphite);
    padding: 3px 0;
    display: flex; align-items: center; gap: 7px;
  }
  .finding-list li::before {
    content: '→';
    color: var(--purple);
    font-size: 11px;
    flex-shrink: 0;
  }
  .finding-list.sometimes li::before { content: '~'; color: #f59e0b; }
  .recommendation-box {
    grid-column: 1 / -1;
    background: var(--purple-light);
    border: 1px solid #c4b5fd;
    border-radius: 8px;
    padding: 14px 16px;
  }
  .recommendation-box .rec-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--purple);
    margin-bottom: 8px;
  }
  .min-fields { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 10px; }
  .badge-min {
    background: var(--purple);
    color: white;
    padding: 3px 10px;
    border-radius: 5px;
    font-size: 11.5px;
    font-weight: 600;
  }
  .conclusion-text {
    font-size: 12.5px;
    color: var(--graphite);
    font-style: italic;
    line-height: 1.5;
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px solid #c4b5fd;
  }
  .pattern-text { font-size: 12.5px; color: var(--graphite); }
  /* PROVIDER PAYMENT METHOD TABLE */
  .ppm-table td.pm-cell .badge-wrap { flex-direction: row; }
  /* GRID FOR CARDS */
  .cards-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  @media (max-width: 800px) { .cards-grid { grid-template-columns: 1fr; } .finding-body { grid-template-columns: 1fr; } }
  .section-block { margin-bottom: 48px; }
  /* FIELD GROUPS in Findings */
  .field-groups {
    grid-column: 1 / -1;
    display: flex;
    gap: 0;
    flex-direction: column;
    gap: 8px;
    background: var(--gray-light);
    border-radius: 8px;
    padding: 14px 16px;
  }
  .field-group {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    flex-wrap: wrap;
  }
  .field-group-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.9px;
    text-transform: uppercase;
    padding: 3px 9px;
    border-radius: 4px;
    white-space: nowrap;
    min-width: 80px;
    text-align: center;
    margin-top: 1px;
  }
  .field-group.core .field-group-label { background: var(--purple); color: white; }
  .field-group.common .field-group-label { background: #ddd6fe; color: #4c1d95; }
  .field-group.additional .field-group-label { background: white; color: var(--gray); border: 1px solid var(--border); }
  .badge-core {
    background: var(--purple); color: white;
    padding: 3px 10px; border-radius: 5px;
    font-size: 11.5px; font-weight: 700;
    border: 1px solid var(--purple);
  }
  .badge-common {
    background: #ede9fc; color: #4c1d95;
    padding: 3px 9px; border-radius: 5px;
    font-size: 11.5px; font-weight: 600;
    border: 1px solid #c4b5fd;
  }
  .badge-additional {
    background: white; color: var(--gray);
    padding: 3px 9px; border-radius: 5px;
    font-size: 11.5px; font-weight: 500;
    border: 1px solid var(--border);
  }
  .findings-legend {
    font-size: 11.5px; color: var(--gray);
    display: flex; gap: 16px; flex-wrap: wrap; align-items: center;
    margin-bottom: 18px;
    padding: 9px 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 7px;
  }
  .legend-item { display: flex; align-items: center; gap: 6px; }
</style>
</head>
